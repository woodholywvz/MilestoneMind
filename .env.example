NODE_ENV=development
NEXT_PUBLIC_AI_BASE_URL=http://localhost:8000
NEXT_PUBLIC_EXECUTOR_BASE_URL=http://localhost:8080
AI_HOST=0.0.0.0
AI_PORT=8000
AI_ASSESSMENT_ENGINE_VERSION=rules-v1
AI_ENABLE_LLM=0
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_OPENAI_MODEL=gpt-5.4-mini
AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_OPENAI_REASONING_EFFORT=medium
AI_OPENAI_TIMEOUT_SECONDS=45
AI_RAG_TOP_K=4
AI_MAX_ATTACHMENT_BYTES=2000000
