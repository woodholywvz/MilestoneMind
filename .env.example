EXECUTOR_HOST=0.0.0.0
EXECUTOR_PORT=8080
SOLANA_CLUSTER=localnet
SOLANA_RPC_URL=http://127.0.0.1:8899
ANCHOR_WALLET=~/.config/solana/id.json
MOCK_USDC_MINT=
MOCK_USDC_DECIMALS=6
