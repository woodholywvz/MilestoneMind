{
  "name": "@milestone-mind/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./idl": {
      "types": "./src/idl.ts",
      "default": "./dist/idl.js"
    },
    "./onchain": {
      "types": "./src/onchain.ts",
      "default": "./dist/onchain.js"
    },
    "./assessment": {
      "types": "./src/assessment.ts",
      "default": "./dist/assessment.js"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./dist/env.js"
    },
    "./evidence": {
      "types": "./src/evidence.ts",
      "default": "./dist/evidence.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./dist/types.js"
    },
    "./milestone-mind": {
      "types": "./src/milestone-mind.ts",
      "default": "./dist/milestone-mind.js"
    }
  },
  "files": [
    "dist",
    "idl"
  ],
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.4",
    "zod": "^3.24.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.json --noEmit"
  }
}
